  },
  "devDependencies": {
    "@hyperswarm/dht-relay": "^0.4.3",
    "brittle": "^3.0.0",
    "dht-relay-tor": "github:ayooooo123/dht-relay-tor",
    "hyperdht": "^6.21.0",
    "prettier": "^3.6.2",
    "prettier-config-holepunch": "^2.0.0"
  },
  "prettier": "prettier-config-holepunch",
